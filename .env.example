# Copy to .env (server reads it at boot; docker compose reads it too)

# Postgres — dev compose exposes 5433; in prod compose the app talks to the db service directly
DATABASE_URL=postgres://lodestar:lodestar@localhost:5433/lodestar

PORT=3000
HOST=0.0.0.0

# REQUIRED in production — long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# true → open sign-up; false → first user only, then invite codes
REGISTRATION_OPEN=false

# Gemini — optional. Unset = heuristic fallbacks everywhere, app fully usable.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Push notifications — optional
NTFY_SERVER=https://ntfy.sh
NTFY_DEFAULT_TOPIC=

# Movie/TV search — optional (books/anime/manga work without any key)
TMDB_API_KEY=

DEFAULT_TZ=Europe/Zurich
